# CroqTuner Agent Bot — copy to `.env` at project root (`scripts/start.sh` sources it).
# Defaults: project = this repo (contains `.claude/skills/`, `kernels/`, `tuning/`).
# Uncomment only to override:

# CROQTUNER_PROJECT_DIR=/absolute/path/to/CroqTuner
# CROQTUNER_TUNING_DIR=/absolute/path/to/CroqTuner/tuning
# CROQTUNER_SKILLS_DIR=/absolute/path/to/CroqTuner/.claude/skills

CROQTUNER_HEARTBEAT_SEC=30
CROQTUNER_DB_PATH=./data/croqtuner.db
CROQTUNER_OPENCODE_BIN=opencode
CROQTUNER_MOCK_MODE=0
CROQTUNER_HOST=0.0.0.0
CROQTUNER_PORT=8642
