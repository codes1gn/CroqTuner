    "e4m3": {
      "best_cu": "/home/albert/workspace/choreo/benchmark/performance/gemm_sp/e4m3_aitune_2026-03-21_iter068/gemm_sp_e4m3_aitune_2026-03-21_iter068.cu",
      "best_tflops": 1127,
